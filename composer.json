{
  "name": "projeto/artigos",
  "description": "Projeto de artigos com PHP, Doctrine ORM e views em PHP.",
  "type": "project",
  "require": {
    "php": "^8.2",
    "doctrine/orm": "^3.2",
    "symfony/cache": "^7.1"
  },
  "autoload": {
    "psr-4": {
      "App\\Config\\": "src/config/",
      "App\\Controller\\": "src/controller/",
      "App\\DAO\\": "src/dao/",
      "App\\Helpers\\": "src/helpers/",
      "App\\Middleware\\": "src/middleware/",
      "App\\Model\\": "src/model/",
      "App\\": "src/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8000 -t public",
    "lint": "php -l public/index.php",
    "smoke": "php scripts/smoke.php",
    "db:check": "php scripts/tidb_check.php",
    "db:init-core": "php scripts/tidb_init_core.php"
  }
}


